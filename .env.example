NEXT_PUBLIC_APP_NAME=WhisperNet
PUBLIC_APP_ORIGIN=https://ashutact.duckdns.org

# Username/password auth. The current prototype does not use these server-side yet,
# but keep them ready for the real backend auth implementation.
AUTH_SESSION_SECRET=replace-with-32-byte-random-secret
PASSWORD_PEPPER=replace-with-server-side-password-pepper
SESSION_COOKIE_NAME=whispernet_session

# Storage/runtime bindings for the planned backend.
D1_BINDING=DB
R2_BINDING=MEDIA

# Abuse protection and push delivery.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
VAPID_PUBLIC_KEY=replace-with-web-push-public-key
VAPID_PRIVATE_KEY=replace-with-web-push-private-key

# App limits.
MAX_TEXT_BYTES=65536
MAX_MEDIA_BYTES=104857600
MAX_GROUP_MEMBERS=512

# Optional if GIF search is proxied by your backend.
GIF_PROVIDER_API_KEY=replace-if-needed
